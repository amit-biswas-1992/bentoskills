# App runtime — use Supabase's transaction pooler (port 6543) so the app
# server can handle many short-lived concurrent queries.
DATABASE_URL=postgresql://postgres.<project>:PASSWORD@<region>.pooler.supabase.com:6543/postgres
# Migrations — must use the session pooler (port 5432) or a direct
# connection, because TypeORM migrations need session-scoped features.
MIGRATION_DATABASE_URL=postgresql://postgres.<project>:PASSWORD@<region>.pooler.supabase.com:5432/postgres
DATABASE_SSL=true

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

GITHUB_ID=
GITHUB_SECRET=

GITHUB_REGISTRY_REPO=amit-biswas-1992/bentoskills-registry
GITHUB_TOKEN=

CRON_SECRET=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
